# Copy to .env (or set these in your host’s environment, e.g. Vercel).
#
# Production build: `npm run build` runs `prisma migrate deploy` then `next build`.
# You must set DATABASE_URL (and migrations must exist) or the build will fail.
# Local compile without touching the DB: npm run build:local
#
# Postgres connection (no Docker required). Install Postgres for your OS, create a DB, then set:
#   postgresql://USER:PASSWORD@localhost:5432/DATABASE
# Example (macOS Homebrew): create role/db in `psql`, then e.g.
#   DATABASE_URL="postgresql://myuser@localhost:5432/tuvy"
# Hosted (Neon, Supabase, Prisma Postgres, RDS): paste the URL from the provider dashboard.
# If you see "Can't reach db.prisma.io", that cloud instance is unreachable—open the provider
# console to resume the project or copy a fresh connection string.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tuvy"

# Used to sign admin session cookies (min ~32 random chars recommended).
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Preferred: bcrypt hash of your password (generate with: npx tsx scripts/hash-admin-password.ts "your-password")
ADMIN_PASSWORD_HASH=""

# Dev-only fallback if ADMIN_PASSWORD_HASH is empty (do not use in production).
ADMIN_PASSWORD=""

# Public site URL for SEO canonicals / Open Graph (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# —— Storefront sign-in (Auth0: Google) ——
# Create a "Regular Web" app in the Auth0 dashboard, enable the Google social connection, then set:
# Same value as NEXT_PUBLIC_SITE_URL in dev (no trailing slash). Auth0 v4 name:
APP_BASE_URL="http://localhost:3000"
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
# openssl rand -hex 32
AUTH0_SECRET=""

# —— Phone OTP SMS (optional in dev: codes are logged to the server console) ——
# Default country when parsing local numbers: ISO 3166-1 alpha-2, e.g. IN for India
PHONE_OTP_DEFAULT_REGION="IN"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""
