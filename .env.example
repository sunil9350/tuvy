# Copy to .env (or set these in your host’s environment, e.g. Vercel).
#
# Production build: `npm run build` runs `prisma migrate deploy` then `next build`.
# You must set DATABASE_URL (and migrations must exist) or the build will fail.
# Local compile without touching the DB: npm run build:local
#
# Prisma Postgres (e.g. Prisma Postgres / Neon / RDS). Use sslmode=require when the host requires TLS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Used to sign admin session cookies (min ~32 random chars recommended).
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Preferred: bcrypt hash of your password (generate with: npx tsx scripts/hash-admin-password.ts "your-password")
ADMIN_PASSWORD_HASH=""

# Dev-only fallback if ADMIN_PASSWORD_HASH is empty (do not use in production).
ADMIN_PASSWORD=""

# Public site URL for SEO canonicals / Open Graph (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
